---
/* T23 — Servicios "El Índice". Full chapter listing. ES root.
 * Each capitulo is an <article> with id="capitulo-<key>" so the home
 * teaser anchors land directly. M02 lorem-marked body until Mireia
 * delivers (per the doctrine update in c75995b). */

import Base from '../../layouts/Base.astro'
import { t } from '../../i18n/t'

const locale = 'es' as const

const items = [
  { key: 'curaduria' },
  { key: 'interiorismo' },
  { key: 'cultural' },
  { key: 'eventos' }
] as const
---

<Base proposal="a"
  locale={locale}
  pathname="/a/servicios"
  title={t('meta.servicios.title', locale)}
  description={t('meta.servicios.description', locale)}
>
  <article class="servicios" data-motion="m-rise">
    <header class="container intro">
      <div class="intro-copy">
        <h1 class="t-page-title">{t('servicios.page_title', locale)}</h1>
        <p class="lead t-lead measure-body">{t('servicios.intro', locale)}</p>
      </div>
    </header>

    <div class="chapters container">
      {
        items.map(({ key }) => {
          const number = t(`servicios.items.${key}.number` as any, locale)
          const title = t(`servicios.items.${key}.title` as any, locale)
          const dedication = t(`servicios.items.${key}.dedication` as any, locale)
          const body = t(`servicios.items.${key}.body` as any, locale)
          return (
            <article id={`capitulo-${key}`} class="capitulo" data-motion="m-rise">
              <p class="numeral">{number}</p>
              <h2 class="t-section-title">{title}</h2>
              <p class="dedication t-lead">{dedication}</p>
              <p class="body measure-body">{body}</p>
              <!-- M02-{i + 1} LOREM -->
            </article>
          )
        })
      }
    </div>
  </article>
</Base>

<style>
  .servicios {
    margin-top: var(--space-24);
    margin-bottom: var(--space-32);
  }
  .intro {
    margin-bottom: var(--space-24);
    align-items: end;
  }
  .intro-copy {
    grid-column: 1 / -1;
  }
  .intro h1 {
    margin-bottom: var(--space-6);
  }
  .lead {
    color: var(--ink-soft);
    max-width: 56ch;
  }
  @media (min-width: 64rem) {
    .intro-copy {
      grid-column: 1 / 8;
    }
  }

  .chapters {
    display: grid;
    gap: var(--space-32);
  }

  .capitulo {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    padding-block: var(--space-12);
    border-top: 1px solid var(--paper-deep);
  }
  @media (min-width: 64rem) {
    .capitulo {
      grid-template-areas:
        'num    title'
        '.      ded'
        '.      body';
      grid-template-columns: 5ch minmax(34rem, 60ch);
      column-gap: var(--space-8);
      row-gap: var(--space-3);
      justify-content: start;
    }
    .capitulo .numeral {
      grid-area: num;
    }
    .capitulo h2 {
      grid-area: title;
    }
    .capitulo .dedication {
      grid-area: ded;
    }
    .capitulo .body {
      grid-area: body;
      max-width: 60ch;
    }
  }

  .numeral {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-3);
    color: var(--library-green);
    line-height: 1;
    margin-bottom: var(--space-2);
  }
  @media (min-width: 64rem) {
    .numeral {
      font-size: var(--step-4);
      align-self: start;
    }
  }

  .capitulo h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-3);
    line-height: 1.15;
  }

  .dedication {
    color: var(--ink-soft);
    margin-top: var(--space-2);
  }

  .body {
    color: var(--ink);
    line-height: 1.6;
    margin-top: var(--space-6);
  }
</style>
