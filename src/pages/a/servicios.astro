---
/* T23 — Servicios "El Índice". Cuatro entradas sobrias.
 * Title + 4 items con un lorem M02 corto al lado de cada uno;
 * Mireia los reemplaza más adelante. Las ramas en acuarela
 * (diagonal-branches) se sitúan centradas detrás del índice
 * como fondo discreto. */

import Base from '../../layouts/Base.astro'
import { t } from '../../i18n/t'
import WatercolorSpot from '../../components/WatercolorSpot.astro'

const locale = 'es' as const

const items = [
  { key: 'curaduria' },
  { key: 'interiorismo' },
  { key: 'cultural' },
  { key: 'eventos' }
] as const
---

<Base proposal="a"
  locale={locale}
  pathname="/a/servicios"
  title={t('meta.servicios.title', locale)}
  description={t('meta.servicios.description', locale)}
>
  <article class="servicios" data-motion="m-rise">
    <div class="branches" aria-hidden="true">
      <WatercolorSpot slug="diagonal-branches-cutout" aspect="3/4" />
    </div>
    <header class="container head">
      <h1 class="t-page-title">{t('servicios.page_title', locale)}</h1>
    </header>

    <div class="container layout">
      <ol class="indice">
        {
          items.map(({ key }) => {
            const number = t(`servicios.items.${key}.number` as any, locale)
            const title = t(`servicios.items.${key}.title` as any, locale)
            const dedication = t(`servicios.items.${key}.dedication` as any, locale)
            const subAtitle = t(`servicios.items.${key}.sub_a_title` as any, locale)
            const subAbody = t(`servicios.items.${key}.sub_a_body` as any, locale)
            const subBtitle = t(`servicios.items.${key}.sub_b_title` as any, locale)
            const subBbody = t(`servicios.items.${key}.sub_b_body` as any, locale)
            return (
              <li id={`capitulo-${key}`} class="entry" data-motion="m-rise">
                <p class="numeral">{number}</p>
                <h2 class="title">{title}</h2>
                <p class="dedication">{dedication}</p>
                <ul class="subservices">
                  <li>
                    <h3 class="sub-title">{subAtitle}</h3>
                    <p class="sub-body">{subAbody}</p>
                  </li>
                  <li>
                    <h3 class="sub-title">{subBtitle}</h3>
                    <p class="sub-body">{subBbody}</p>
                  </li>
                </ul>
              </li>
            )
          })
        }
      </ol>

    </div>
  </article>
</Base>

<style>
  .servicios {
    position: relative;
    margin-top: var(--space-24);
    margin-bottom: var(--space-32);
    overflow-x: clip;
  }

  .head {
    margin-bottom: var(--space-16);
  }
  .head h1 {
    margin: 0;
  }

  .layout {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
  }

  .indice {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
    position: relative;
    z-index: 1;
  }

  .entry {
    display: grid;
    grid-template-columns: 4ch 1fr;
    column-gap: var(--space-6);
    row-gap: var(--space-1);
    align-items: baseline;
    padding-block: var(--space-8);
    border-top: 1px solid var(--paper-deep);
  }
  .entry:last-child {
    border-bottom: 1px solid var(--paper-deep);
  }
  @media (min-width: 64rem) {
    .entry {
      grid-template-columns: 5ch 1fr;
      column-gap: var(--space-8);
      padding-block: var(--space-20, 80px);
      row-gap: var(--space-3);
    }
  }

  .numeral {
    grid-row: 1 / span 2;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-3);
    color: var(--library-green);
    line-height: 1;
    margin: 0;
  }
  @media (min-width: 64rem) {
    .numeral {
      font-size: var(--step-4);
    }
  }

  .title {
    grid-column: 2;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-2);
    line-height: 1.2;
    margin: 0;
  }
  @media (min-width: 64rem) {
    .title {
      font-size: var(--step-3);
    }
  }

  .dedication {
    grid-column: 2;
    color: var(--ink-soft);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-0);
    line-height: 1.4;
    margin: 0;
    max-width: 48ch;
  }
  @media (min-width: 64rem) {
    .dedication {
      font-size: var(--step-1);
    }
  }

  .subservices {
    grid-column: 2;
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-6);
  }
  @media (min-width: 64rem) {
    .subservices {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
      margin-top: var(--space-8);
    }
  }
  .subservices > li {
    max-width: 44ch;
  }

  .sub-title {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--library-green);
    margin: 0 0 var(--space-2);
  }

  .sub-body {
    color: var(--ink-soft);
    font-size: var(--step-0);
    line-height: 1.55;
    margin: 0;
  }

  .branches {
    display: none;
  }
  @media (min-width: 64rem) {
    .branches {
      display: block;
      position: absolute;
      top: 50%;
      right: 0;
      transform: translateY(-50%);
      width: min(40vw, 608px);
      pointer-events: none;
      z-index: 0;
    }
    .branches :global(.watercolor-spot) {
      opacity: 0.7;
      transform: scaleX(-1);
    }
  }
</style>
