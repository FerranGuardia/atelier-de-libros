---
/* T23 — Servicios "El Índice". Full chapter listing. ES root.
 * Each capitulo is an <article> with id="capitulo-<key>" so the home
 * teaser anchors land directly. M02 lorem-marked body until Mireia
 * delivers (per the doctrine update in c75995b). */

import Base from '../layouts/Base.astro'
import WatercolorSpot from '../components/WatercolorSpot.astro'
import { t } from '../i18n/t'

const locale = 'es' as const

const items = [
  { key: 'curaduria', token: 'offered-fragment' },
  { key: 'interiorismo', token: 'library-arch' },
  { key: 'cultural', token: 'ink-path-valley' },
  { key: 'eventos', token: 'reading-lectern' }
] as const
---

<Base
  locale={locale}
  pathname="/servicios"
  title={t('meta.servicios.title', locale)}
  description={t('meta.servicios.description', locale)}
>
  <article class="servicios" data-motion="m-rise">
    <header class="container intro">
      <div class="intro-copy">
        <h1 class="t-page-title">{t('servicios.page_title', locale)}</h1>
        <p class="lead t-lead measure-body">{t('servicios.intro', locale)}</p>
      </div>
      <WatercolorSpot
        class="intro-ornament"
        slug="diagonal-branches"
        aspect="3/4"
      />
    </header>

    <div class="chapters container">
      {
        items.map(({ key, token }) => {
          const number = t(`servicios.items.${key}.number` as any, locale)
          const title = t(`servicios.items.${key}.title` as any, locale)
          const dedication = t(`servicios.items.${key}.dedication` as any, locale)
          const body = t(`servicios.items.${key}.body` as any, locale)
          return (
            <article id={`capitulo-${key}`} class="capitulo" data-motion="m-rise">
              <p class="numeral">{number}</p>
              <h2 class="t-section-title">{title}</h2>
              <p class="dedication t-lead">{dedication}</p>
              <p class="body measure-body">{body}</p>
              <WatercolorSpot
                class="chapter-token"
                slug={token}
                aspect="3/4"
              />
              <!-- M02-{i + 1} LOREM -->
            </article>
          )
        })
      }
    </div>
  </article>
</Base>

<style>
  .servicios {
    margin-top: var(--space-24);
    margin-bottom: var(--space-32);
  }
  .intro {
    margin-bottom: var(--space-24);
    align-items: end;
  }
  .intro-copy {
    grid-column: 1 / -1;
  }
  .intro h1 {
    margin-bottom: var(--space-6);
  }
  .lead {
    color: var(--ink-soft);
    max-width: 56ch;
  }
  .intro :global(.intro-ornament) {
    grid-column: 1 / -1;
    width: min(74vw, 260px);
    justify-self: end;
    margin-top: var(--space-8);
    opacity: 0.5;
  }
  @media (min-width: 64rem) {
    .intro-copy {
      grid-column: 1 / 8;
    }
    .intro :global(.intro-ornament) {
      grid-column: 7 / 11;
      width: min(100%, 390px);
      justify-self: start;
      align-self: center;
      margin-top: 0;
      opacity: 0.58;
    }
  }

  .chapters {
    display: grid;
    gap: var(--space-32);
  }

  .capitulo {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    padding-block: var(--space-12);
    border-top: 1px solid var(--paper-deep);
  }
  .capitulo :global(.chapter-token) {
    width: min(72vw, 230px);
    opacity: 0.44;
    margin-top: var(--space-4);
  }
  @media (min-width: 64rem) {
    .capitulo {
      grid-template-areas:
        'num    title token'
        '.      ded   token'
        '.      body  token';
      grid-template-columns: 5ch minmax(34rem, 60ch) 300px;
      column-gap: var(--space-12);
      row-gap: var(--space-3);
      justify-content: start;
    }
    .capitulo .numeral {
      grid-area: num;
    }
    .capitulo h2 {
      grid-area: title;
    }
    .capitulo .dedication {
      grid-area: ded;
    }
    .capitulo .body {
      grid-area: body;
      max-width: 60ch;
    }
    .capitulo :global(.chapter-token) {
      grid-area: token;
      align-self: center;
      justify-self: start;
      width: min(100%, 300px);
      margin-top: 0;
      opacity: 0.5;
    }
  }

  .numeral {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-3);
    color: var(--library-green);
    line-height: 1;
    margin-bottom: var(--space-2);
  }
  @media (min-width: 64rem) {
    .numeral {
      font-size: var(--step-4);
      align-self: start;
    }
  }

  .capitulo h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-3);
    line-height: 1.15;
  }

  .dedication {
    color: var(--ink-soft);
    margin-top: var(--space-2);
  }

  .body {
    color: var(--ink);
    line-height: 1.6;
    margin-top: var(--space-6);
  }
</style>
