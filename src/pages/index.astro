---
/* ES home — root route. Other locales: src/pages/[lang]/index.astro.
 * Hero + sections land in T15-T22 via shared page components. */

import Base from '../layouts/Base.astro'
import { t } from '../i18n/t'

const locale = 'es' as const
---

<Base locale={locale} pathname="/">
  <main id="main">
    <h1 class="t-hero">{t('home.hero.headline_part_1', locale)}</h1>
    <p>i18n smoke: <code>nav.home → {t('nav.home', locale)}</code></p>
  </main>

  <style>
    main {
      max-width: 60ch;
      margin: var(--space-24) auto;
      padding: 0 var(--space-6);
    }
  </style>
</Base>
