---
/* ES home — root route. T15 puts the Hero in place; T17-T22 will fill
 * the rest of the home (manifesto, services teaser, portfolio teaser,
 * epilogue CTA). */

import Base from '../layouts/Base.astro'
import Hero from '../components/sections/Hero.astro'

const locale = 'es' as const
---

<Base locale={locale} pathname="/">
  <Hero locale={locale} />
</Base>
