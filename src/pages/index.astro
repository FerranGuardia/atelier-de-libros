---
/* Hub de propuestas — ES (raíz). Dos tarjetas grandes. Sin chrome.
 * /a → propuesta editorial (la web actual). /b → propuesta product-led. */

import { Image } from 'astro:assets'
import Base from '../layouts/Base.astro'
import editorialDesk from '../assets/watercolor/editorial-desk.png'
import readerIsland from '../assets/watercolor/reader-paper-island.png'

const locale = 'es' as const
---

<Base
  locale={locale}
  pathname="/"
  bare
  title="Atelier de Libros · Propuestas"
  description="Selección entre dos direcciones de diseño para la web."
  noindex
>
  <main class="hub" id="main">
    <header class="hub-head">
      <p class="t-wordmark mark">Atelier de Libros</p>
      <h1 class="t-page-title head">Dos propuestas</h1>
      <p class="t-lead lead">Misma identidad, dos formas de presentarla. Entra y compara.</p>
    </header>

    <section class="cards">
      <a class="card" href="/a/" aria-label="Abrir propuesta A — editorial">
        <div class="thumb">
          <Image
            src={editorialDesk}
            alt=""
            widths={[480, 720, 1024]}
            sizes="(min-width: 64rem) 42vw, 92vw"
            quality={82}
          />
        </div>
        <div class="meta">
          <p class="num">A</p>
          <h2 class="title">Editorial introspectiva</h2>
          <p class="kicker">Manifiesto, voz literaria, ritmo lento. La web como pieza editorial.</p>
          <span class="cta">Entrar →</span>
        </div>
      </a>

      <a class="card" href="/b/" aria-label="Abrir propuesta B — comercial">
        <div class="thumb">
          <Image
            src={readerIsland}
            alt=""
            widths={[480, 720, 1024]}
            sizes="(min-width: 64rem) 42vw, 92vw"
            quality={82}
          />
        </div>
        <div class="meta">
          <p class="num">B</p>
          <h2 class="title">Comercial directa</h2>
          <p class="kicker">Servicios, casos, contacto. Lo que hacemos, sin floritura.</p>
          <span class="cta">Entrar →</span>
        </div>
      </a>
    </section>
  </main>
</Base>

<style>
  .hub {
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: var(--space-12);
    padding: var(--space-10) var(--space-6) var(--space-16);
    max-width: 1280px;
    margin-inline: auto;
  }

  .hub-head {
    display: grid;
    gap: var(--space-3);
    text-align: left;
  }
  .mark {
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .head {
    margin: 0;
  }
  .lead {
    color: var(--ink-soft);
    max-width: 52ch;
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-content: center;
  }
  @media (min-width: 64rem) {
    .cards {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }
  }

  .card {
    display: grid;
    grid-template-rows: auto auto;
    gap: var(--space-6);
    text-decoration: none;
    color: var(--ink);
    padding: var(--space-6);
    border: 1px solid var(--paper-deep);
    background: var(--paper);
    transition:
      transform var(--dur) var(--ease),
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }
  .card:hover,
  .card:focus-visible {
    transform: translateY(-2px);
    border-color: var(--library-green);
    box-shadow: 0 16px 48px -24px rgba(45, 64, 51, 0.25);
  }
  .card:focus-visible {
    outline: 2px solid var(--library-green);
    outline-offset: 4px;
  }

  .thumb {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--paper-deep);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .meta {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto auto;
    column-gap: var(--space-6);
    row-gap: var(--space-2);
    align-items: baseline;
  }
  .num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-4);
    line-height: 1;
    color: var(--library-green);
    grid-row: 1 / span 3;
    align-self: start;
  }
  .title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-2);
    line-height: 1.15;
    margin: 0;
  }
  .kicker {
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 42ch;
  }
  .cta {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--step--1);
    color: var(--library-green);
    margin-top: var(--space-2);
  }
</style>
