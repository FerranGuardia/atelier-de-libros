---
/* ES home — root route. Hero + manifesto + sections built in T15-T22.
 * For now a stub-with-chrome so the layout shell can be QA'd. */

import Base from '../layouts/Base.astro'
import { t } from '../i18n/t'

const locale = 'es' as const
---

<Base locale={locale} pathname="/">
  <section class="container intro">
    <h1 class="t-hero">{t('home.hero.headline_part_1', locale)}</h1>
    <p class="t-lead measure-body">{t('home.hero.subheadline', locale)}</p>
  </section>
</Base>

<style>
  .intro {
    margin-block: var(--space-24);
  }
  .intro h1 {
    margin-bottom: var(--space-6);
  }
</style>
