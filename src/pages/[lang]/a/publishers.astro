---
import Base from '../../../layouts/Base.astro'
import PublishersPage from '../../../components/pages/PublishersPage.astro'
import { locales, defaultLocale, type Locale } from '../../../i18n/config'
import { t } from '../../../i18n/t'

export function getStaticPaths() {
  return locales
    .filter((code) => code !== defaultLocale)
    .map((code) => ({ params: { lang: code } }))
}

const lang = Astro.params.lang as Locale
---

<Base proposal="a"
  locale={lang}
  pathname="/a/publishers"
  title={t('meta.publishers.title', lang)}
  description={t('meta.publishers.description', lang)}
  noindex
>
  <PublishersPage locale={lang} />
</Base>
