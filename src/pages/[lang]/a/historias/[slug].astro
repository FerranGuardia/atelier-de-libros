---
import Base from '../../../../layouts/Base.astro'
import HistoriaDetail from '../../../../components/pages/HistoriaDetail.astro'
import { locales, defaultLocale, type Locale } from '../../../../i18n/config'
import { t } from '../../../../i18n/t'

export function getStaticPaths() {
  const slugs = [
    { slug: '_lorem-1', caseId: 'lorem_1' as const },
    { slug: '_lorem-2', caseId: 'lorem_2' as const },
    { slug: '_lorem-3', caseId: 'lorem_3' as const }
  ]
  const langs = locales.filter((code) => code !== defaultLocale)
  return langs.flatMap((lang) =>
    slugs.map(({ slug, caseId }) => ({ params: { lang, slug }, props: { caseId } }))
  )
}

const { caseId } = Astro.props
const lang = Astro.params.lang as Locale
const title = t(`historias.cases.${caseId}.title` as any, lang)
---

<Base proposal="a"
  locale={lang}
  pathname={`/a/historias/${Astro.params.slug}`}
  title={`${title} — ${t('meta.historias.title', lang)}`}
  description={t(`historias.cases.${caseId}.excerpt` as any, lang)}
>
  <HistoriaDetail locale={lang} caseId={caseId} />
</Base>
