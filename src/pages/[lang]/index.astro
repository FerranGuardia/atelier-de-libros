---
/* Hub de propuestas — locales no-ES. Reusa la pantalla raíz. */

import { Image } from 'astro:assets'
import Base from '../../layouts/Base.astro'
import editorialDesk from '../../assets/watercolor/editorial-desk.png'
import readerIsland from '../../assets/watercolor/reader-paper-island.png'
import { locales, defaultLocale, type Locale } from '../../i18n/config'

export function getStaticPaths() {
  return locales
    .filter((code) => code !== defaultLocale)
    .map((code) => ({ params: { lang: code } }))
}

const lang = Astro.params.lang as Locale
---

<Base locale={lang} pathname="/" bare noindex title="Atelier de Libros · Propuestas">
  <main class="hub" id="main">
    <header class="hub-head">
      <p class="t-wordmark mark">Atelier de Libros</p>
      <h1 class="t-page-title head">Dos propuestas</h1>
    </header>

    <section class="cards">
      <a class="card" href={`/${lang}/a/`}>
        <div class="thumb">
          <Image src={editorialDesk} alt="" widths={[480, 720, 1024]} sizes="(min-width: 64rem) 42vw, 92vw" quality={82} />
        </div>
        <div class="meta">
          <p class="num">A</p>
          <h2 class="title">Editorial introspectiva</h2>
          <span class="cta">Entrar →</span>
        </div>
      </a>

      <a class="card" href="/b/">
        <div class="thumb">
          <Image src={readerIsland} alt="" widths={[480, 720, 1024]} sizes="(min-width: 64rem) 42vw, 92vw" quality={82} />
        </div>
        <div class="meta">
          <p class="num">B</p>
          <h2 class="title">Comercial directa</h2>
          <span class="cta">Entrar →</span>
        </div>
      </a>
    </section>
  </main>
</Base>

<style>
  .hub { min-height: 100vh; min-height: 100dvh; display: grid; grid-template-rows: auto 1fr; gap: var(--space-12); padding: var(--space-10) var(--space-6) var(--space-16); max-width: 1280px; margin-inline: auto; }
  .hub-head { display: grid; gap: var(--space-3); }
  .mark { text-transform: uppercase; color: var(--ink-soft); }
  .head { margin: 0; }
  .cards { display: grid; grid-template-columns: 1fr; gap: var(--space-10); align-content: center; }
  @media (min-width: 64rem) { .cards { grid-template-columns: 1fr 1fr; gap: var(--space-12); } }
  .card { display: grid; gap: var(--space-6); text-decoration: none; color: var(--ink); padding: var(--space-6); border: 1px solid var(--paper-deep); background: var(--paper); transition: transform var(--dur) var(--ease), border-color var(--dur) var(--ease); }
  .card:hover, .card:focus-visible { transform: translateY(-2px); border-color: var(--library-green); }
  .thumb { aspect-ratio: 4 / 3; overflow: hidden; background: var(--paper-deep); }
  .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .meta { display: grid; grid-template-columns: auto 1fr; column-gap: var(--space-6); align-items: baseline; }
  .num { font-family: var(--font-display); font-style: italic; font-size: var(--step-4); color: var(--library-green); grid-row: 1 / span 2; }
  .title { font-family: var(--font-display); font-weight: 400; font-size: var(--step-2); margin: 0; }
  .cta { text-transform: uppercase; letter-spacing: 0.08em; font-size: var(--step--1); color: var(--library-green); }
</style>
