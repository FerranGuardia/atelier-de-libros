---
/* T22 — Home assembly, localized routes (/ca/, /fr/, /en/, /it/).
 * Mirrors the ES home; i18n resolver falls back to ES until Mireia /
 * translators deliver per-locale copy. */

import Base from '../../layouts/Base.astro'
import Hero from '../../components/sections/Hero.astro'
import Manifesto from '../../components/sections/Manifesto.astro'
import ServicesTeaser from '../../components/sections/ServicesTeaser.astro'
import PortfolioTeaser from '../../components/sections/PortfolioTeaser.astro'
import EpilogueCTA from '../../components/sections/EpilogueCTA.astro'
import { locales, defaultLocale, type Locale } from '../../i18n/config'

export function getStaticPaths() {
  return locales
    .filter((code) => code !== defaultLocale)
    .map((code) => ({ params: { lang: code } }))
}

const lang = Astro.params.lang as Locale
---

<Base locale={lang} pathname="/">
  <Hero locale={lang} />
  <Manifesto locale={lang} />
  <ServicesTeaser locale={lang} />
  <PortfolioTeaser locale={lang} />
  <EpilogueCTA locale={lang} />
</Base>
