---
/* T23 — Servicios for non-default locales. Mirror of /servicios. */

import Base from '../../layouts/Base.astro'
import { locales, defaultLocale, type Locale } from '../../i18n/config'
import { t } from '../../i18n/t'

export function getStaticPaths() {
  return locales
    .filter((code) => code !== defaultLocale)
    .map((code) => ({ params: { lang: code } }))
}

const lang = Astro.params.lang as Locale

const items = [
  { key: 'curaduria' },
  { key: 'interiorismo' },
  { key: 'cultural' },
  { key: 'eventos' }
] as const
---

<Base
  locale={lang}
  pathname="/servicios"
  title={t('meta.servicios.title', lang)}
  description={t('meta.servicios.description', lang)}
>
  <article class="servicios" data-motion="m-rise">
    <header class="container intro">
      <h1 class="t-page-title">{t('servicios.page_title', lang)}</h1>
      <p class="lead t-lead measure-body">{t('servicios.intro', lang)}</p>
    </header>

    <div class="chapters container">
      {
        items.map(({ key }) => {
          const number = t(`servicios.items.${key}.number` as any, lang)
          const title = t(`servicios.items.${key}.title` as any, lang)
          const dedication = t(`servicios.items.${key}.dedication` as any, lang)
          const body = t(`servicios.items.${key}.body` as any, lang)
          return (
            <article id={`capitulo-${key}`} class="capitulo" data-motion="m-rise">
              <p class="numeral">{number}</p>
              <h2 class="t-section-title">{title}</h2>
              <p class="dedication t-lead">{dedication}</p>
              <p class="body measure-body">{body}</p>
            </article>
          )
        })
      }
    </div>
  </article>
</Base>

<style>
  .servicios {
    margin-top: var(--space-24);
    margin-bottom: var(--space-32);
  }
  .intro {
    margin-bottom: var(--space-24);
  }
  .intro h1 {
    margin-bottom: var(--space-6);
  }
  .lead {
    color: var(--ink-soft);
    max-width: 56ch;
  }
  .chapters {
    display: grid;
    gap: var(--space-32);
  }
  .capitulo {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    padding-block: var(--space-12);
    border-top: 1px solid var(--paper-deep);
  }
  @media (min-width: 64rem) {
    .capitulo {
      grid-template-columns: 5ch 1fr;
      grid-template-areas: 'num title' '. ded' '. body';
      column-gap: var(--space-8);
      row-gap: var(--space-3);
    }
    .capitulo .numeral {
      grid-area: num;
    }
    .capitulo h2 {
      grid-area: title;
    }
    .capitulo .dedication {
      grid-area: ded;
    }
    .capitulo .body {
      grid-area: body;
      max-width: 60ch;
    }
  }
  .numeral {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-3);
    color: var(--library-green);
    line-height: 1;
  }
  @media (min-width: 64rem) {
    .numeral {
      font-size: var(--step-4);
      align-self: start;
    }
  }
  .capitulo h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-3);
    line-height: 1.15;
  }
  .dedication {
    color: var(--ink-soft);
    margin-top: var(--space-2);
  }
  .body {
    color: var(--ink);
    line-height: 1.6;
    margin-top: var(--space-6);
  }
</style>
