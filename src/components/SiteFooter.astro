---
/* Site footer. Studio block · legal + contact.
 * Bottom strip: copyright in --ink-whisper, centred. */

import { localizePath } from '../i18n/locale'
import { t, type Key } from '../i18n/t'
import type { Locale } from '../i18n/config'
import WatercolorSpot from './WatercolorSpot.astro'

interface Props {
  locale: Locale
  pathname: string
}

const { locale } = Astro.props

const legal: { key: Key; href: string }[] = [
  { key: 'footer.legal.imprint', href: '/legal/imprint' },
  { key: 'footer.legal.privacy', href: '/legal/privacy' },
  { key: 'footer.legal.cookies', href: '/legal/cookies' }
]
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-token" aria-hidden="true">
      <WatercolorSpot slug="ink-thread-cutout" aspect="3/2" />
    </div>
    <section class="col studio">
      <p class="t-wordmark">{t('brand.wordmark', locale)}</p>
      <p class="tagline">{t('brand.tagline', locale)}</p>
      <p class="colofon t-caption measure-caption">{t('footer.colophon', locale)}</p>
    </section>

    <section class="col contact">
      <p class="col-label">{t('footer.column_legal', locale)}</p>
      <ul class="legal">
        {
          legal.map(({ key, href }) => (
            <li>
              <a href={localizePath(href, locale)}>{t(key, locale)}</a>
            </li>
          ))
        }
      </ul>
      <p class="col-label">{t('epilogo.contact_email_label', locale)}</p>
      <a class="email" href={`mailto:${t('epilogo.contact_email', locale)}`}>
        {t('epilogo.contact_email', locale)}
      </a>
    </section>
  </div>

  <div class="copyright">
    <p>{t('footer.copyright', locale)}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--paper-deep);
    padding-block: var(--space-16, 64px);
    margin-top: var(--space-24);
  }
  @media (min-width: 64rem) {
    .site-footer {
      padding-block: var(--space-20, 80px) var(--space-12);
    }
  }
  @media (min-width: 90rem) {
    .site-footer {
      padding-block: var(--space-24, 96px) var(--space-16);
    }
  }

  .site-footer .container {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  .footer-token {
    display: none;
  }
  @media (min-width: 64rem) {
    .footer-token {
      display: block;
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      display: grid;
      place-items: center;
    }
    .footer-token :global(.watercolor-spot) {
      width: min(38%, 420px);
      opacity: 0.55;
    }
    .site-footer .col {
      position: relative;
      z-index: 1;
    }
  }
  @media (min-width: 64rem) {
    .site-footer .container {
      grid-template-columns: 1fr auto;
      gap: var(--space-20, 80px);
    }
    .site-footer .col.contact {
      justify-self: end;
      text-align: right;
    }
  }
  @media (min-width: 90rem) {
    .site-footer .container {
      gap: var(--space-24, 96px);
    }
  }

  .col-label {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-whisper);
    margin-bottom: var(--space-3);
  }

  .studio .t-wordmark {
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: var(--space-2);
  }
  .studio .tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    color: var(--ink-soft);
    margin-bottom: var(--space-6);
  }
  .colofon {
    color: var(--ink-soft);
    line-height: 1.55;
  }

  .legal {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8);
    display: grid;
    gap: var(--space-2);
  }
  .legal a {
    color: var(--ink-soft);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: var(--step--1);
  }
  .legal a:hover,
  .legal a:focus-visible {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .email {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-0);
    color: var(--ink-soft);
    text-decoration: none;
    border-bottom: 1px solid var(--ink-whisper);
    padding-bottom: 2px;
  }
  .email:hover,
  .email:focus-visible {
    color: var(--ink);
    border-bottom-color: var(--library-green);
  }

  .copyright {
    margin-top: var(--space-16);
    text-align: center;
    color: var(--ink-whisper);
    font-family: var(--font-body);
    font-size: var(--step--1);
  }
</style>
