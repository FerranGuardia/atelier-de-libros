---
/* T11 — Site footer. Implements T09 spec. Three columns desktop,
 * stacked mobile. Studio block · nav repeat + language switcher · contact.
 * Bottom strip: copyright in --ink-whisper, centred. */

import LanguageSwitcher from './LanguageSwitcher.astro'
import { localizePath } from '../i18n/locale'
import { t, type Key } from '../i18n/t'
import type { Locale } from '../i18n/config'

interface Props {
  locale: Locale
  pathname: string
}

const { locale, pathname } = Astro.props

const navItems: { key: Key; href: string }[] = [
  { key: 'nav.manifiesto', href: '/#manifiesto' },
  { key: 'nav.servicios', href: '/servicios' },
  { key: 'nav.publishers', href: '/publishers' },
  { key: 'nav.historias', href: '/historias' },
  { key: 'nav.nota', href: '/nota' },
  { key: 'nav.epilogo', href: '/epilogo' }
]

const legal: { key: Key; href: string }[] = [
  { key: 'footer.legal.imprint', href: '/legal/imprint' },
  { key: 'footer.legal.privacy', href: '/legal/privacy' },
  { key: 'footer.legal.cookies', href: '/legal/cookies' }
]
---

<footer class="site-footer">
  <div class="container">
    <section class="col studio">
      <p class="t-wordmark">{t('brand.wordmark', locale)}</p>
      <p class="tagline">{t('brand.tagline', locale)}</p>
      <p class="colofon t-caption measure-caption">{t('footer.colophon', locale)}</p>
    </section>

    <section class="col directory">
      <p class="col-label">{t('footer.column_studio', locale)}</p>
      <nav aria-label={t('aria.footer_nav', locale)}>
        <ul>
          {
            navItems.map(({ key, href }) => (
              <li>
                <a
                  data-motion="m-underline-roll"
                  href={
                    href.startsWith('/#')
                      ? localizePath('/', locale) + href.slice(1)
                      : localizePath(href, locale)
                  }
                >
                  {t(key, locale)}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <div class="lang">
        <p class="col-label">{t('footer.column_languages', locale)}</p>
        <LanguageSwitcher current={locale} pathname={pathname} />
      </div>
    </section>

    <section class="col contact">
      <p class="col-label">{t('footer.column_legal', locale)}</p>
      <ul class="legal">
        {
          legal.map(({ key, href }) => (
            <li>
              <a href={localizePath(href, locale)}>{t(key, locale)}</a>
            </li>
          ))
        }
      </ul>
      <p class="col-label">{t('epilogo.contact_email_label', locale)}</p>
      <a class="email" href={`mailto:${t('epilogo.contact_email', locale)}`}>
        {t('epilogo.contact_email', locale)}
      </a>
    </section>
  </div>

  <div class="copyright">
    <p>{t('footer.copyright', locale)}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--paper-deep);
    padding-block: var(--space-16);
    margin-top: var(--space-32);
  }

  .site-footer .container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }
  @media (min-width: 64rem) {
    .site-footer .container {
      grid-template-columns: 1.2fr 1fr 1fr;
      gap: var(--space-16);
    }
  }

  .col-label {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-whisper);
    margin-bottom: var(--space-3);
  }

  .studio .t-wordmark {
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: var(--space-2);
  }
  .studio .tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    color: var(--ink-soft);
    margin-bottom: var(--space-6);
  }
  .colofon {
    color: var(--ink-soft);
    line-height: 1.55;
  }

  .directory ul {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8);
    display: grid;
    gap: var(--space-2);
  }
  .directory a {
    color: var(--ink);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .directory a:hover,
  .directory a:focus-visible {
    color: var(--library-green);
  }
  .lang {
    margin-top: var(--space-6);
  }

  .legal {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8);
    display: grid;
    gap: var(--space-2);
  }
  .legal a {
    color: var(--ink-soft);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: var(--step--1);
  }
  .legal a:hover,
  .legal a:focus-visible {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .email {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-1);
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--library-green);
    padding-bottom: 2px;
  }
  .email:hover,
  .email:focus-visible {
    color: var(--library-green);
  }

  .copyright {
    margin-top: var(--space-16);
    text-align: center;
    color: var(--ink-whisper);
    font-family: var(--font-body);
    font-size: var(--step--1);
  }
</style>
