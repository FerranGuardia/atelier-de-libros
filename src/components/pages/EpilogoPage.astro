---
/* T28 — Epílogo / Contacto. Form with Formspree-compatible action.
 * Fields: name, email, project, qualifying-question (--step-1, larger
 * than the rest), message. Honeypot field + aria-live success region.
 *
 * The Formspree endpoint is a placeholder until T39 provisions a
 * real form ID. The form uses native HTML `action` + `method="post"`
 * so it works without JS — JS layers the m-form-success transition. */

import { t } from '../../i18n/t'
import WatercolorSpot from '../WatercolorSpot.astro'
import type { Locale } from '../../i18n/config'

interface Props {
  locale: Locale
}
const { locale } = Astro.props

/* Replace with the real Formspree endpoint in T39. The placeholder
 * accepts the submission shape but does not deliver email. */
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/PLACEHOLDER_T39'
---

<article class="epilogo" data-motion="m-rise">
  <header class="container grid intro">
    <div class="intro-copy">
      <h1 class="t-page-title">{t('epilogo.page_title', locale)}</h1>
      <p class="lead t-lead measure-body">{t('epilogo.intro', locale)}</p>
    </div>
    <WatercolorSpot
      class="intro-ornament"
      slug="offered-fragment"
      aspect="3/4"
    />
  </header>

  <div
    class="container form-wrap"
    data-motion="m-form-success"
    data-state="form"
    id="contact-form-wrap"
  >
    <form
      class="contact-form"
      method="post"
      action={FORMSPREE_ENDPOINT}
      novalidate
      aria-describedby="form-legal"
    >
      <p class="field">
        <label for="f-name">{t('epilogo.form.name_label', locale)}</label>
        <input id="f-name" name="name" type="text" required aria-required="true" />
      </p>
      <p class="field">
        <label for="f-email">{t('epilogo.form.email_label', locale)}</label>
        <input id="f-email" name="email" type="email" required aria-required="true" />
      </p>

      <p class="field">
        <label for="f-message">{t('epilogo.form.message_label', locale)}</label>
        <textarea
          id="f-message"
          name="message"
          rows="6"
          placeholder={t('epilogo.form.message_placeholder', locale)}
        ></textarea>
      </p>

      <p class="field" aria-hidden="true" hidden>
        <label for="f-honey">Leave this field empty</label>
        <input id="f-honey" name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
      </p>

      <p id="form-legal" class="legal t-caption">{t('epilogo.form.legal_consent', locale)}</p>

      <button class="submit" type="submit">
        <span class="submit-label">{t('epilogo.form.submit_label', locale)}</span>
      </button>
    </form>

    <div data-form-success role="status" aria-live="polite">
      <p class="success-title t-page-title">{t('epilogo.form.success_title', locale)}</p>
      <p class="success-body t-lead measure-body">{t('epilogo.form.success_body', locale)}</p>
    </div>
  </div>

  <div class="container direct-email">
    <span class="col-label">{t('epilogo.contact_email_label', locale)}</span>
    <a class="email" href={`mailto:${t('epilogo.contact_email', locale)}`}>
      {t('epilogo.contact_email', locale)}
    </a>
  </div>
</article>

<script>
  /* Layer the success transition + Formspree XHR over the native form.
   * Without JS, the form posts and Formspree returns its default thanks
   * page — the page degrades cleanly. */
  document.addEventListener('astro:page-load', () => {
    const wrap = document.getElementById('contact-form-wrap')
    const form = wrap?.querySelector<HTMLFormElement>('.contact-form')
    if (!wrap || !form) return
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const data = new FormData(form)
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' }
        })
        if (res.ok) wrap.dataset.state = 'success'
        else wrap.dataset.state = 'error'
      } catch {
        wrap.dataset.state = 'error'
      }
    })
  })
</script>

<style>
  .epilogo {
    margin-top: var(--space-24);
    margin-bottom: var(--space-32);
  }
  .intro {
    margin-bottom: var(--space-20);
    align-items: end;
  }
  @media (min-width: 64rem) {
    .intro {
      margin-bottom: var(--space-24);
    }
  }
  .intro-copy {
    grid-column: 1 / -1;
  }
  .intro h1 {
    margin-bottom: var(--space-6);
  }
  .lead {
    color: var(--ink-soft);
    max-width: 56ch;
  }
  .intro :global(.intro-ornament) {
    grid-column: 1 / -1;
    width: min(72vw, 230px);
    justify-self: end;
    margin-top: var(--space-6);
    opacity: 0.5;
  }
  @media (min-width: 64rem) {
    .intro-copy {
      grid-column: 1 / 7;
    }
    .intro :global(.intro-ornament) {
      grid-column: 7 / 11;
      width: min(100%, 340px);
      justify-self: start;
      align-self: center;
      margin-top: 0;
      opacity: 0.6;
    }
  }

  .form-wrap {
    max-width: calc(42rem + 2 * var(--container-pad));
    margin-inline: auto;
  }

  .contact-form {
    display: grid;
    gap: var(--space-6);
  }

  .field {
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }
  .field[hidden] {
    display: none;
  }

  label {
    font-family: var(--font-body);
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  input[type='text'],
  input[type='email'],
  textarea {
    background: transparent;
    border: 1px solid var(--paper-deep);
    padding: var(--space-4) var(--space-5);
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.4;
    color: var(--ink);
    width: 100%;
    transition: border-color 700ms cubic-bezier(0.2, 0.6, 0.2, 1);
  }
  input::placeholder,
  textarea::placeholder {
    color: var(--ink-whisper);
    font-style: italic;
  }
  input:hover,
  textarea:hover {
    border-color: var(--ink-whisper);
  }
  input:focus-visible,
  textarea:focus-visible {
    outline: none;
    border-color: var(--ink);
  }
  textarea {
    resize: vertical;
    min-height: 9rem;
  }

  .legal {
    color: var(--ink-soft);
    margin: var(--space-2) 0 0;
    line-height: 1.55;
  }

  .submit {
    justify-self: start;
    margin-top: var(--space-4);
    background: transparent;
    border: 1px solid var(--ink);
    color: var(--ink);
    padding: var(--space-4) var(--space-10);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    min-height: 44px;
    transition:
      background-color 700ms cubic-bezier(0.2, 0.6, 0.2, 1),
      color 700ms cubic-bezier(0.2, 0.6, 0.2, 1);
  }
  .submit:hover,
  .submit:focus-visible {
    background: var(--ink);
    color: var(--paper);
  }

  [data-form-success] {
    display: none;
    text-align: center;
    padding-block: var(--space-16);
  }
  [data-form-success] p + p {
    margin-top: var(--space-6);
  }

  [data-state='success'] form {
    display: none;
  }
  [data-state='success'] [data-form-success] {
    display: block;
  }

  .direct-email {
    margin-top: var(--space-32);
    padding-top: var(--space-16);
    border-top: 1px solid var(--paper-deep);
    text-align: center;
    display: grid;
    gap: var(--space-4);
    justify-items: center;
    max-width: calc(42rem + 2 * var(--container-pad));
  }
  .col-label {
    font-family: var(--font-body);
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-whisper);
  }
  .email {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-1);
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--library-green);
    padding-bottom: 4px;
  }
</style>
