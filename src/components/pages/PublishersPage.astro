---
/* T24 — Publishers' Room body. Letter-style page (56ch measure).
 * Direct, business voice; pull-quote inline. M03 lorem until Mireia
 * delivers. */

import WatercolorSpot from '../WatercolorSpot.astro'
import { t } from '../../i18n/t'
import { localizePath } from '../../i18n/locale'
import type { Locale } from '../../i18n/config'

interface Props {
  locale: Locale
}
const { locale } = Astro.props
---

<article class="publishers" data-motion="m-rise">
  <header class="container intro">
    <p class="eyebrow t-caption">Publishers</p>
    <h1 class="t-page-title">{t('publishers.headline', locale)}</h1>
  </header>

  <div class="container letter measure-letter">
    <p class="body">{t('publishers.body_1', locale)}</p>
    <p class="body">{t('publishers.body_2', locale)}</p>
    <blockquote class="pull">
      <WatercolorSpot
        class="pull-ornament"
        slug="correction-wreath"
        aspect="3/4"
      />
      <p>{t('publishers.pullquote', locale)}</p>
    </blockquote>
    <p class="body">{t('publishers.body_3', locale)}</p>
    <p class="body">{t('publishers.body_4', locale)}</p>
    <a
      class="cta"
      href={localizePath('/epilogo?ref=publishers', locale)}
      data-motion="m-underline-roll"
    >
      {t('publishers.cta', locale)}
    </a>
    <!-- M03 LOREM -->
  </div>
</article>

<style>
  .publishers {
    margin-top: var(--space-24);
    margin-bottom: var(--space-32);
  }
  .intro {
    margin-bottom: var(--space-16);
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-whisper);
    margin-bottom: var(--space-3);
  }
  .intro h1 {
    max-width: 22ch;
  }
  .letter {
    margin-inline: auto;
    max-width: 56ch + 2 * var(--container-pad);
  }
  .body {
    margin-bottom: var(--space-6);
    line-height: 1.65;
  }
  .pull {
    margin: var(--space-12) 0;
    padding-left: var(--space-6);
    border-left: 1px solid var(--library-green);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-2);
    color: var(--ink);
    line-height: 1.3;
    max-width: 38ch;
    position: relative;
  }
  .pull p {
    margin: 0;
  }
  .pull :global(.pull-ornament) {
    position: absolute;
    width: clamp(190px, 22vw, 300px);
    right: calc(-1 * var(--space-16));
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.44;
  }
  @media (max-width: 47.99rem) {
    .pull :global(.pull-ornament) {
      display: none;
    }
  }
  .cta {
    display: inline-block;
    margin-top: var(--space-8);
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--library-green);
    padding-bottom: 4px;
  }
</style>
