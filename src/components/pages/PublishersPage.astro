---
/* «Para editoriales» — TFM §2 (El Ecosistema Editorial: del product
 * placement a la prescripción estética). Tres ejes verbatim extraídos
 * de §2.X.2: activación de backlist, contextualización estética, acceso
 * a nuevos gatekeepers. Sustituye el logo wall por una página de tesis
 * editorial — ningún cliente se reclama hasta que exista. */

import { t } from '../../i18n/t'
import { localizePath } from '../../i18n/locale'
import WatercolorSpot from '../WatercolorSpot.astro'
import type { Locale } from '../../i18n/config'

interface Props {
  locale: Locale
}
const { locale } = Astro.props

const axes = ['1', '2', '3'] as const
---

<article class="editoriales" data-motion="m-rise">
  <div class="hero">
    <header class="intro">
      <p class="eyebrow t-caption">{t('publishers.eyebrow', locale)}</p>
      <h1 class="t-page-title">{t('publishers.headline', locale)}</h1>
      <p class="lead">{t('publishers.lead', locale)}</p>
    </header>
    <div class="ornament" aria-hidden="true">
      <WatercolorSpot slug="open-book-landscape" aspect="3/2" />
    </div>
  </div>

  <ol class="container axes" role="list">
    {
      axes.map((n) => {
        const eyebrow = t(`publishers.axis_${n}_eyebrow` as any, locale)
        const title = t(`publishers.axis_${n}_title` as any, locale)
        const body = t(`publishers.axis_${n}_body` as any, locale)
        return (
          <li class="axis" data-motion="m-rise">
            <p class="axis-numeral">{eyebrow}</p>
            <h2 class="axis-title">{title}</h2>
            <p class="axis-body">{body}</p>
          </li>
        )
      })
    }
  </ol>

  <footer class="container outro">
    <p class="closer">{t('publishers.closer', locale)}</p>
    <a
      class="cta"
      href={localizePath('/epilogo?ref=editoriales', locale)}
      data-motion="m-underline-roll"
    >
      {t('publishers.cta', locale)}
    </a>
  </footer>
</article>

<style>
  .editoriales {
    margin-top: var(--space-24);
    margin-bottom: var(--space-32);
  }

  /* Hero band: intro text on the left with container padding,
   * watercolor flush to the viewport's right edge, vertically
   * centered together. Mobile: ornament hides, intro returns to
   * container padding. */
  .hero {
    display: grid;
    gap: var(--space-10);
    margin-bottom: var(--space-16);
  }
  @media (min-width: 48rem) {
    .hero {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      column-gap: var(--space-12);
      align-items: center;
      padding-inline-start: var(--container-pad);
    }
  }
  @media (max-width: 47.99rem) {
    .hero {
      padding-inline: var(--container-pad);
    }
  }

  .intro {
    max-width: 64ch;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-whisper);
    margin-bottom: var(--space-3);
  }
  .intro h1 {
    max-width: 24ch;
    margin-bottom: var(--space-6);
  }
  .lead {
    color: var(--ink-soft);
    line-height: 1.55;
    font-size: var(--step-0);
  }

  .ornament {
    opacity: 0.78;
  }
  /* PNG has transparent margin around the brushstroke — anchor the
   * painted content to the right edge so it sits flush in its corner. */
  .ornament :global(.watercolor-spot) {
    object-position: right center;
  }
  @media (max-width: 47.99rem) {
    .ornament {
      display: none;
    }
  }

  .axes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .axis {
    display: grid;
    grid-template-columns: 4ch 1fr;
    column-gap: var(--space-6);
    row-gap: var(--space-2);
    align-items: baseline;
    padding-block: var(--space-10);
    border-top: 1px solid var(--paper-deep);
  }
  .axis:last-child {
    border-bottom: 1px solid var(--paper-deep);
  }
  @media (min-width: 64rem) {
    .axis {
      grid-template-columns: 5ch 1fr;
      column-gap: var(--space-8);
      padding-block: var(--space-16);
    }
  }

  .axis-numeral {
    grid-row: 1 / span 2;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-3);
    color: var(--library-green);
    line-height: 1;
    margin: 0;
  }
  @media (min-width: 64rem) {
    .axis-numeral {
      font-size: var(--step-4);
    }
  }

  .axis-title {
    grid-column: 2;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-2);
    line-height: 1.2;
    margin: 0;
  }
  @media (min-width: 64rem) {
    .axis-title {
      font-size: var(--step-3);
    }
  }

  .axis-body {
    grid-column: 2;
    color: var(--ink-soft);
    font-size: var(--step-0);
    line-height: 1.6;
    margin: 0;
    max-width: 58ch;
  }

  .outro {
    max-width: 64ch;
    margin-top: var(--space-16);
    padding-top: var(--space-10);
  }
  .closer {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    color: var(--ink);
    font-size: var(--step-1);
    line-height: 1.45;
    margin-bottom: var(--space-8);
    max-width: 56ch;
  }
  .cta {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--library-green);
    padding-bottom: 4px;
  }
</style>
