---
/* T27 — La Nota de la Autora. Editorial article with portrait slot. */

import { Image } from 'astro:assets'
import portraitSrc from '../../assets/portrait/mireia.jpg'
import { t } from '../../i18n/t'
import type { Locale } from '../../i18n/config'

interface Props {
  locale: Locale
}
const { locale } = Astro.props
---

<article class="nota" data-motion="m-rise">
  <header class="container intro">
    <p class="eyebrow t-caption">{t('nota.eyebrow', locale)}</p>
    <h1 class="t-page-title">{t('nota.page_title', locale)}</h1>
  </header>

  <div class="container layout">
    <div class="body measure-letter">
      <p class="drop-cap">{t('nota.body_1', locale)}</p>
      <p>{t('nota.body_2', locale)}</p>
      <p>{t('nota.body_3', locale)}</p>
      <p>{t('nota.body_4', locale)}</p>
      <p>{t('nota.body_5', locale)}</p>
      <p>{t('nota.body_6', locale)}</p>
      <p class="signature">
        <span class="signature-credit">{t('nota.signature_credit', locale)}</span>
      </p>
      <!-- M04 DRAFT (anclado en TFM §1.1/§1.2) — tasks-mireia/M04 -->
    </div>

    <aside class="portrait">
      <Image
        class="portrait-photo img-sepia"
        src={portraitSrc}
        alt="Mireia García Domènech"
        widths={[320, 480, 640, 800]}
        sizes="(min-width: 64rem) 20rem, 100vw"
        loading="lazy"
        decoding="async"
        quality={82}
      />
      <p class="portrait-caption t-caption">{t('nota.portrait_caption', locale)}</p>
    </aside>
  </div>
</article>

<style>
  .nota {
    margin-top: var(--space-16);
    margin-bottom: var(--space-32);
  }
  @media (min-width: 64rem) {
    .nota {
      margin-top: var(--space-20);
    }
  }

  .intro {
    margin-bottom: var(--space-10);
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-whisper);
    margin-bottom: var(--space-3);
  }

  .layout {
    display: grid;
    gap: var(--space-10);
    align-items: start;
  }
  @media (min-width: 64rem) {
    .layout {
      grid-template-columns: minmax(0, 42rem) 20rem;
      gap: var(--space-14);
      align-items: start;
    }
    .body {
      grid-column: 1;
    }
    .portrait {
      grid-column: 2;
      position: sticky;
      top: calc(72px + var(--space-12));
    }
  }

  .body p {
    margin-bottom: var(--space-6);
    line-height: 1.7;
  }
  .body p:first-child {
    margin-top: 0;
  }

  .signature {
    margin-top: var(--space-12);
  }
  .signature-credit {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: var(--step-1);
    color: var(--ink);
  }

  .portrait-photo {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center 28%;
  }

  .portrait .portrait-caption {
    margin-top: var(--space-3);
    color: var(--ink-soft);
  }
</style>
