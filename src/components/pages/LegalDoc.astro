---
/* Shared legal document layout. Renders one of three documents
 * (imprint, privacy, cookies) from the locale-aware copy in
 * src/content/legal.ts. */

interface Section {
  heading: string
  /** Inline HTML allowed (paragraphs and anchors). */
  body: string
  /** Optional unordered list rendered under the body. */
  list?: readonly string[]
}

interface Props {
  eyebrow: string
  title: string
  lead: string
  sections: readonly Section[]
  updatedLabel: string
  updatedDate: string
}

const { eyebrow, title, lead, sections, updatedLabel, updatedDate } = Astro.props
---

<article class="legal" data-motion="m-rise">
  <header class="container intro">
    <p class="eyebrow t-caption">{eyebrow}</p>
    <h1 class="t-page-title">{title}</h1>
    <p class="lead measure-letter">{lead}</p>
    <p class="updated t-caption">
      <span>{updatedLabel}:</span> {updatedDate}
    </p>
  </header>

  <div class="container body measure-letter">
    {
      sections.map((s) => (
        <section class="block">
          <h2 class="t-section-title">{s.heading}</h2>
          <p set:html={s.body} />
          {s.list && (
            <ul>
              {s.list.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
        </section>
      ))
    }
  </div>
</article>

<style>
  .legal {
    padding-block: var(--space-16) var(--space-24);
  }
  .intro {
    display: grid;
    gap: var(--space-4);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--paper-deep);
    margin-bottom: var(--space-12);
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-whisper);
  }
  .lead {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-1);
    color: var(--ink-soft);
    line-height: 1.4;
    max-width: 52ch;
  }
  .updated {
    color: var(--ink-whisper);
    margin-top: var(--space-2);
  }
  .updated span {
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .body {
    display: grid;
    gap: var(--space-12);
    max-width: 64ch;
  }
  .block {
    display: grid;
    gap: var(--space-4);
  }
  .block h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1.2;
    color: var(--ink);
    margin: 0;
  }
  .block p {
    line-height: 1.7;
    color: var(--ink-soft);
  }
  .block p :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--ink-whisper);
    text-underline-offset: 3px;
  }
  .block p :global(a:hover),
  .block p :global(a:focus-visible) {
    text-decoration-color: var(--library-green);
  }
  .block p :global(strong) {
    color: var(--ink);
    font-weight: 500;
  }
  .block ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-2);
  }
  .block ul li {
    line-height: 1.6;
    color: var(--ink-soft);
    padding-left: var(--space-4);
    position: relative;
  }
  .block ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--library-green);
  }
</style>
