---
/* T31 — Illustration component. Renders the named illustration if its
 * raster (PNG/WebP) has landed under src/assets/illustrations/<slug>.*;
 * otherwise falls back to <PendingImage>. The slot map below is the
 * single source of truth — adding a new slug requires (a) a prompt MD
 * under .claude/image-prompts/, (b) the asset file, and (c) an entry
 * here.
 *
 * Post-pivot (T13/T30 watercolor aesthetic): illustrations are raster
 * assets, not SVG. When each lands, swap the placeholder branch below
 * for an Astro <Image> import — see .claude/illustrations.md
 * "Integration pattern" for the canonical snippet. */

import PendingImage from './PendingImage.astro'

interface Props {
  /** Slug from the registry: `hero | open-book | hand-page | shelf | bookmark | page-fold`. */
  slug:
    | 'hero'
    | 'open-book'
    | 'hand-page'
    | 'shelf'
    | 'bookmark'
    | 'page-fold'
  /** ViewBox-derived aspect, used by the placeholder until the asset
   * lands (the SVG itself ignores this). */
  aspect?: string
  /** Human-readable label for the placeholder + aria-label. */
  label?: string
  /** Optional hint shown in the placeholder legend. */
  hint?: string
  /** Class hook for layout placement. */
  class?: string
}

const {
  slug,
  aspect = '3/2',
  label = 'Ilustración pendiente',
  hint,
  class: className = ''
} = Astro.props

/* Per-slug prompt MD slug. Matches .claude/image-prompts/<value>.md. */
const promptMap: Record<Props['slug'], string> = {
  hero: 'T13-hero',
  'open-book': 'T30-illustration-set',
  'hand-page': 'T30-illustration-set',
  shelf: 'T30-illustration-set',
  bookmark: 'T30-illustration-set',
  'page-fold': 'T30-illustration-set'
}

/* When each asset lands, import it from src/assets/illustrations/ and
 * render through Astro's <Image>:
 *
 *   import { Image } from 'astro:assets'
 *   import heroSrc from '../assets/illustrations/hero.png'
 *
 * Then pass the matching src into the Image branch below. Until then,
 * every slug routes to the <PendingImage> placeholder. */
const rasterSrcs: Partial<Record<Props['slug'], string>> = {}

const src = rasterSrcs[slug]
---

{
  src ? (
    <img
      src={src}
      alt=""
      class:list={['illustration', className]}
      style={`--aspect: ${aspect};`}
      loading="lazy"
      decoding="async"
    />
  ) : (
    <PendingImage
      class={className}
      prompt={promptMap[slug]}
      aspect={aspect}
      illustration
      label={label}
      hint={hint}
      ariaLabel=""
    />
  )
}

<style>
  .illustration {
    display: block;
    aspect-ratio: var(--aspect);
    width: 100%;
    height: auto;
  }
</style>
