---
/* T31 — Illustration component. Renders local SVG ornaments when they
 * exist, otherwise falls back to <PendingImage>. */

import PendingImage from './PendingImage.astro'
import bookmarkSvg from '../assets/illustrations/bookmark.svg?raw'
import handPageSvg from '../assets/illustrations/hand-page.svg?raw'
import openBookSvg from '../assets/illustrations/open-book.svg?raw'
import pageFoldSvg from '../assets/illustrations/page-fold.svg?raw'
import shelfSvg from '../assets/illustrations/shelf.svg?raw'

interface Props {
  /** Slug from the registry: `hero | open-book | hand-page | shelf | bookmark | page-fold`. */
  slug:
    | 'hero'
    | 'open-book'
    | 'hand-page'
    | 'shelf'
    | 'bookmark'
    | 'page-fold'
  /** ViewBox-derived aspect, used by the placeholder until the asset
   * lands (the SVG itself ignores this). */
  aspect?: string
  /** Human-readable label for the placeholder + aria-label. */
  label?: string
  /** Optional hint shown in the placeholder legend. */
  hint?: string
  /** Class hook for layout placement. */
  class?: string
}

const {
  slug,
  aspect = '3/2',
  label = 'Ilustración pendiente',
  hint,
  class: className = ''
} = Astro.props

/* Per-slug prompt MD slug. Matches .claude/image-prompts/<value>.md. */
const promptMap: Record<Props['slug'], string> = {
  hero: 'T13-hero',
  'open-book': 'T30-illustration-set',
  'hand-page': 'T30-illustration-set',
  shelf: 'T30-illustration-set',
  bookmark: 'T30-illustration-set',
  'page-fold': 'T30-illustration-set'
}

const svgMap: Partial<Record<Props['slug'], string>> = {
  'open-book': openBookSvg,
  'hand-page': handPageSvg,
  shelf: shelfSvg,
  bookmark: bookmarkSvg,
  'page-fold': pageFoldSvg
}

const svg = svgMap[slug]
---

{
  svg ? (
    <span
      class:list={['illustration', className]}
      style={`--aspect: ${aspect};`}
      aria-hidden="true"
      set:html={svg}
    />
  ) : (
    <PendingImage
      class={className}
      prompt={promptMap[slug]}
      aspect={aspect}
      illustration
      label={label}
      hint={hint}
      ariaLabel=""
    />
  )
}

<style>
  .illustration {
    display: block;
    aspect-ratio: var(--aspect);
    width: 100%;
    height: auto;
    color: var(--library-green);
  }
  .illustration :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
</style>
