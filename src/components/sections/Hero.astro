---
/* T15 (revised after the watercolor pivot) — Hero. The illustration
 * is now a full-bleed atmospheric backdrop (cols 1-12 at desktop). The
 * headline and sub-headline overlay on the left half, where the
 * watercolor's cream-paper negative space sits. The original asymmetric
 * brief (small illustration cols 9-11) was downgrading the asset; the
 * GRIS-volume painting deserves the whole canvas. */

import { Image } from 'astro:assets'
import heroSrc from '../../assets/illustrations/hero-atelier.png'
import { t } from '../../i18n/t'
import type { Locale } from '../../i18n/config'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
---

<section class="hero" aria-labelledby="hero-title" data-hero>
  <Image
    class="hero-image"
    src={heroSrc}
    alt=""
    widths={[640, 960, 1280, 1600, 2000, 2400]}
    sizes="(min-width: 64rem) 100vw, 100vw"
    loading="eager"
    fetchpriority="high"
    quality={85}
  />

  <div class="hero-content container">
    <div class="text-block">
      <h1 id="hero-title" class="t-hero" data-hero-headline>
        <span class="line" data-motion="m-mask-wipe">
          {t('home.hero.headline_part_1', locale)}
        </span>
        <span class="line" data-motion="m-mask-wipe">
          {t('home.hero.headline_part_2', locale)}
        </span>
      </h1>
      <p class="subhead t-lead" data-motion="m-fade-in" data-hero-subhead>
        {t('home.hero.subheadline', locale)}
      </p>
    </div>
  </div>
</section>

<script is:inline>
  /* Pre-paint: mark JS available before the page paints, so the CSS
   * entrance state below is gated on this class. Without JS the hero
   * renders fully visible from the static HTML — no FOIC. */
  document.documentElement.classList.add('js-ready')
</script>

<script>
  /* Hero entrance choreography per T14 timeline (post-pivot: the
   * illustration uses an opacity rise instead of m-stroke-draw — the
   * watercolor isn't strokeable). */

  function reveal() {
    const root = document.querySelector<HTMLElement>('[data-hero]')
    if (!root) return
    if (root.dataset.entered === 'true') return
    root.dataset.entered = 'true'

    const headline = root.querySelector<HTMLElement>('[data-hero-headline]')
    const lines = headline
      ? Array.from(headline.querySelectorAll<HTMLElement>('.line'))
      : []
    const subhead = root.querySelector<HTMLElement>('[data-hero-subhead]')
    const image = root.querySelector<HTMLElement>('.hero-image')

    requestAnimationFrame(() => {
      image?.setAttribute('data-in-view', '')

      lines.forEach((line, i) => {
        line.style.transitionDelay = `${200 + i * 120}ms`
        line.setAttribute('data-in-view', '')
      })

      if (subhead) {
        subhead.style.transitionDelay = '1100ms'
        subhead.setAttribute('data-in-view', '')
      }
    })
  }

  document.addEventListener('astro:page-load', reveal)
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    align-items: center;
    padding-block: calc(var(--space-16) + 72px) var(--space-16);
    overflow: hidden;
  }
  @media (max-width: 47.99rem) {
    .hero {
      padding-block: calc(var(--space-12) + 56px) var(--space-12);
    }
  }

  /* The watercolor sits behind the text. On desktop / tablet it covers
   * the entire hero, anchored so the book composition lives on the
   * right and the cream-paper negative space falls under the headline.
   * On mobile it sits above the headline as a contained block. */

  .hero-image {
    width: 100%;
    height: auto;
    display: block;
    opacity: 0;
    transition: opacity var(--dur) var(--ease);
  }
  .hero-image[data-in-view] {
    opacity: 1;
  }

  @media (min-width: 48rem) {
    .hero-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      /* Keep the book + figure visible; let the cream-paper left edge
       * extend off-screen so the headline gets the room it needs. */
      object-position: 70% center;
      z-index: 0;
    }
  }

  @media (max-width: 47.99rem) {
    .hero-image {
      max-width: 100%;
      margin-bottom: var(--space-8);
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .text-block {
    /* Width is controlled by the headline's own clamp + line-by-line
     * spans below, not by a parent max-width (ch units on the parent
     * compute against the body font-size and would force the huge
     * display headline into a tiny column). */
    width: fit-content;
    max-width: 100%;
  }

  /* Hero typography is its own thing — competing with the watercolor
   * at full --step-5 would shout. Reduce one or two steps so the
   * painting reads first and the words settle in second. */
  #hero-title {
    font-size: clamp(2rem, 0.9rem + 3.6vw, 3.4rem);
    line-height: 1.1;
    max-width: none;
  }
  #hero-title .line {
    display: block;
    white-space: nowrap;
  }

  .subhead {
    color: var(--ink-soft);
    margin-top: var(--space-6);
    max-width: 32ch;
    font-size: clamp(1.1rem, 0.9rem + 0.5vw, 1.4rem);
  }
  @media (min-width: 64rem) {
    .subhead {
      max-width: 32ch;
    }
  }

  @media (min-width: 64rem) {
    .text-block {
      padding-block: var(--space-16);
      padding-left: var(--space-6);
    }
  }

  /* Pre-JS entrance state. Without `.js-ready`, the hero is fully
   * visible (no animation, no FOIC). */

  .js-ready .hero-image {
    opacity: 0;
  }
  .js-ready .hero-image[data-in-view] {
    opacity: 1;
  }

  .js-ready [data-hero-subhead] {
    opacity: 0;
    transition: opacity var(--dur) var(--ease);
  }
  .js-ready [data-hero-subhead][data-in-view] {
    opacity: 1;
  }

  .js-ready #hero-title .line {
    clip-path: inset(0 100% 0 0);
    transition: clip-path var(--dur) var(--ease);
  }
  .js-ready #hero-title .line[data-in-view] {
    clip-path: inset(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .js-ready #hero-title .line {
      clip-path: none;
      opacity: 0;
      transition: opacity var(--dur-fast) var(--ease);
    }
    .js-ready #hero-title .line[data-in-view] {
      opacity: 1;
    }
  }
</style>
