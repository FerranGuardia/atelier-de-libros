---
/* T15 — Hero. Implements composition (T12), illustration (T13 prompt /
 * pending-image placeholder), and motion choreography (T14).
 *
 * No composition / motion / image decisions in this file — it follows
 * the three spec docs exactly. */

import PendingImage from '../PendingImage.astro'
import { t } from '../../i18n/t'
import type { Locale } from '../../i18n/config'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
---

<section class="hero" aria-labelledby="hero-title" data-hero>
  <div class="container grid">
    <div class="headline-wrap col-2-7">
      <h1 id="hero-title" class="t-hero" data-hero-headline>
        <span class="line" data-motion="m-mask-wipe">
          {t('home.hero.headline_part_1', locale)}
        </span>
        <span class="line" data-motion="m-mask-wipe">
          {t('home.hero.headline_part_2', locale)}
        </span>
      </h1>
    </div>

    <p class="subhead t-lead col-2-5" data-motion="m-fade-in" data-hero-subhead>
      {t('home.hero.subheadline', locale)}
    </p>

    <div class="illustration col-9-11" data-motion="m-parallax-soft" data-hero-illustration>
      <PendingImage
        prompt="T13-hero"
        aspect="3/2"
        illustration
        label={t('home.hero.headline_part_2', locale)}
        hint="Open book on spine · single library-green stroke"
        ariaLabel=""
      />
    </div>
  </div>
</section>

<script is:inline>
  /* Pre-paint: mark JS available before the page paints, so the CSS
   * entrance state below is gated on this class. Without JS the hero
   * renders fully visible from the static HTML — no FOIC. */
  document.documentElement.classList.add('js-ready')
</script>

<script>
  /* Hero entrance choreography per T14 timeline. Wires once per route
   * via Astro's astro:page-load (so it survives View Transitions). */

  function reveal() {
    const root = document.querySelector<HTMLElement>('[data-hero]')
    if (!root) return
    if (root.dataset.entered === 'true') return
    root.dataset.entered = 'true'

    const headline = root.querySelector<HTMLElement>('[data-hero-headline]')
    const lines = headline
      ? Array.from(headline.querySelectorAll<HTMLElement>('.line'))
      : []
    const subhead = root.querySelector<HTMLElement>('[data-hero-subhead]')
    const illust = root.querySelector<HTMLElement>('[data-hero-illustration]')

    /* Reveal in stages. The data-in-view flag is what motion.css watches. */
    requestAnimationFrame(() => {
      illust?.setAttribute('data-in-view', '')

      lines.forEach((line, i) => {
        line.style.transitionDelay = `${200 + i * 120}ms`
        line.setAttribute('data-in-view', '')
      })

      if (subhead) {
        subhead.style.transitionDelay = '1100ms'
        subhead.setAttribute('data-in-view', '')
      }
    })
  }

  function mountParallax() {
    const illust = document.querySelector<HTMLElement>('[data-hero-illustration]')
    const hero = document.querySelector<HTMLElement>('[data-hero]')
    if (!illust || !hero) return () => {}

    const onScroll = () => {
      const { top, height } = hero.getBoundingClientRect()
      const vh = window.innerHeight || 1
      const progress = Math.max(0, Math.min(1, -top / (height + vh)))
      illust.style.setProperty('--parallax-y', `${-progress * 24}px`)
    }
    onScroll()
    window.addEventListener('scroll', onScroll, { passive: true })
    return () => window.removeEventListener('scroll', onScroll)
  }

  let teardown: (() => void) | null = null
  document.addEventListener('astro:page-load', () => {
    reveal()
    teardown?.()
    teardown = mountParallax()
  })
  document.addEventListener('astro:before-swap', () => {
    teardown?.()
    teardown = null
  })
</script>

<style>
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    align-items: center;
    padding-block: var(--space-16);
    contain: layout paint;
  }

  .hero > .container {
    align-items: start;
    row-gap: var(--space-8);
  }

  /* Mobile order: illustration → headline → sub-head (T07: stack). */

  .illustration {
    order: 1;
    width: 60vw;
    max-width: 220px;
    margin-inline: auto;
  }
  .headline-wrap {
    order: 2;
  }
  .subhead {
    order: 3;
    color: var(--ink-soft);
  }

  .subhead {
    max-width: 32ch;
  }

  /* Desktop: asymmetric placement per T12 ASCII grid. */

  @media (min-width: 64rem) {
    .hero > .container {
      align-items: center;
      min-height: 80vh;
    }
    .headline-wrap {
      order: 0;
      transform: translateY(-80px);
      align-self: center;
    }
    .subhead {
      order: 0;
      align-self: center;
      transform: translateY(-80px);
      margin-top: var(--space-8);
      max-width: 38ch;
    }
    .illustration {
      order: 0;
      align-self: center;
      transform: translateY(120px);
      width: 280px;
      max-width: none;
    }
  }

  @media (min-width: 48rem) and (max-width: 63.99rem) {
    .hero > .container {
      align-items: center;
      min-height: 80vh;
    }
    .headline-wrap {
      order: 0;
    }
    .subhead {
      order: 0;
      margin-top: var(--space-6);
    }
    .illustration {
      order: 0;
      align-self: start;
      transform: translateY(90px);
      width: 220px;
    }
  }

  /* Headline line wrapping. Each line is its own clip-path scope. */

  #hero-title {
    /* Override the typography.css clamp at the desktop edge:
     * the hero on this page is the only target; clamp() handles
     * all responsive cases. */
  }
  #hero-title .line {
    display: block;
  }

  /* Pre-JS entrance state. Without `.js-ready`, the hero is fully
   * visible (no animation, no FOIC). With JS, the entrance state is
   * applied; the controller above flips data-in-view to reveal. */

  .js-ready [data-hero-subhead] {
    opacity: 0;
    transition: opacity var(--dur) var(--ease);
  }
  .js-ready [data-hero-subhead][data-in-view] {
    opacity: 1;
  }

  .js-ready #hero-title .line {
    clip-path: inset(0 100% 0 0);
    transition: clip-path var(--dur) var(--ease);
  }
  .js-ready #hero-title .line[data-in-view] {
    clip-path: inset(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .js-ready #hero-title .line {
      clip-path: none;
      opacity: 0;
      transition: opacity var(--dur-fast) var(--ease);
    }
    .js-ready #hero-title .line[data-in-view] {
      opacity: 1;
    }
  }
</style>
