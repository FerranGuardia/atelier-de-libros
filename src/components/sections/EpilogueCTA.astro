---
/* T21 — Epilogue CTA. Single line headline + link, with the home page's
 * one library-green-soft atmospheric wash. Mobile drops the wash (per
 * T17 §6 — keep mobile quiet). The wash is the only on-page hint of
 * green; the rest of the page must reserve its 8% budget for it. */

import { t } from '../../i18n/t'
import { localizePath } from '../../i18n/locale'
import WatercolorSpot from '../WatercolorSpot.astro'
import type { Locale } from '../../i18n/config'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
---

<section
  id="epilogo"
  class="epilogue"
  aria-labelledby="epilogue-title"
  data-motion="m-rise"
>
  <div class="container">
    <WatercolorSpot
      class="cta-token"
      slug="correction-wreath"
      aspect="3/4"
    />
    <p class="eyebrow t-caption">{t('home.epilogo_cta.eyebrow', locale)}</p>
    <p id="epilogue-title" class="headline t-page-title">
      {t('home.epilogo_cta.headline', locale)}
    </p>
    <a
      class="cta"
      href={localizePath('/epilogo', locale)}
      data-motion="m-underline-roll"
    >
      {t('home.epilogo_cta.cta', locale)}
    </a>
  </div>
</section>

<style>
  .epilogue {
    margin-top: var(--space-24);
    margin-bottom: var(--space-24);
    background: transparent;
    padding-block: var(--space-24);
  }

  @media (max-width: 47.99rem) {
    .epilogue {
      padding-block: var(--space-16);
      margin-top: var(--space-16);
    }
  }

  .container {
    text-align: center;
    display: grid;
    gap: var(--space-6);
    justify-items: center;
  }
  .container :global(.cta-token) {
    width: clamp(180px, 22vw, 300px);
    margin-bottom: calc(-1 * var(--space-3));
    opacity: 0.5;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-whisper);
  }

  .headline {
    /* T-page-title carries the weight; we override the default colour
     * to ink (not ink-soft) — the question is the page's invitation. */
    color: var(--ink);
    max-width: 28ch;
    line-height: 1.15;
  }
  /* Italic the closing question mark phrase — Cormorant italic does
   * the work of emphasis without an underline. */
  .headline {
    font-style: italic;
    font-weight: 300;
  }

  .cta {
    margin-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--library-green);
    padding-bottom: 4px;
  }
</style>
