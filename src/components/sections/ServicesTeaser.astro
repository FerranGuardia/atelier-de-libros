---
/* T19 — Services teaser. *El Índice*: 4 chapter rows, each linking to
 * the corresponding chapter on /servicios. Roman numerals beside titles
 * desktop / above titles mobile. Hover/focus uses m-row-tint from the
 * catalog (numeral shifts +6px, row tints library-green-soft). */

import WatercolorSpot from '../WatercolorSpot.astro'
import { t } from '../../i18n/t'
import { localizePath } from '../../i18n/locale'
import type { Locale } from '../../i18n/config'

interface Props {
  locale: Locale
}

const { locale } = Astro.props

const items = [
  { key: 'curaduria' },
  { key: 'interiorismo' },
  { key: 'cultural' },
  { key: 'eventos' }
] as const

const serviciosHref = localizePath('/servicios', locale)
---

<section
  id="indice"
  class="services-teaser"
  aria-labelledby="services-teaser-title"
  data-motion="m-rise"
>
  <header class="container">
    <div class="header-copy">
      <p class="eyebrow t-caption">{t('home.servicios_teaser.eyebrow', locale)}</p>
      <h2 id="services-teaser-title" class="t-section-title">
        {t('home.servicios_teaser.title', locale)}
      </h2>
      <p class="lead measure-body">
        {t('home.servicios_teaser.lead', locale)}
      </p>
    </div>
    <WatercolorSpot
      class="section-ornament"
      slug="ink-path-valley"
      aspect="3/4"
    />
  </header>

  <ol class="container index">
    {
      items.map(({ key }) => {
        const number = t(`servicios.items.${key}.number` as any, locale)
        const title = t(`servicios.items.${key}.title` as any, locale)
        const dedication = t(`servicios.items.${key}.dedication` as any, locale)
        return (
          <li data-motion="m-row-tint">
            <a href={`${serviciosHref}#capitulo-${key}`} class="row">
              <span class="numeral" data-row-numeral>
                {number}
              </span>
              <span class="title">{title}</span>
              <span class="dedication">{dedication}</span>
            </a>
          </li>
        )
      })
    }
  </ol>

  <div class="container cta-row">
    <a class="cta" href={serviciosHref} data-motion="m-underline-roll">
      {t('home.servicios_teaser.cta', locale)}
    </a>
  </div>
  <!-- M02-1..4 LOREM (dedications + body) — see tasks-mireia/M02 -->
</section>

<style>
  .services-teaser {
    margin-top: var(--space-24);
    margin-bottom: var(--space-32);
  }
  @media (max-width: 47.99rem) {
    .services-teaser {
      margin-top: var(--space-16);
      margin-bottom: var(--space-24);
    }
  }

  header {
    margin-bottom: var(--space-12);
    align-items: end;
  }
  .header-copy {
    grid-column: 1 / -1;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-whisper);
    margin-bottom: var(--space-4);
  }
  .lead {
    color: var(--ink-soft);
    margin-top: var(--space-3);
    max-width: 56ch;
  }
  header :global(.section-ornament) {
    grid-column: 1 / -1;
    width: min(72vw, 240px);
    justify-self: end;
    margin-top: var(--space-6);
    opacity: 0.48;
  }
  @media (min-width: 64rem) {
    .header-copy {
      grid-column: 1 / 7;
    }
    header h2 {
      max-width: 18ch;
    }
    header :global(.section-ornament) {
      grid-column: 7 / 11;
      width: min(100%, 360px);
      justify-self: start;
      align-self: center;
      margin-top: 0;
      opacity: 0.62;
    }
  }

  .index {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--paper-deep);
  }
  .index li {
    border-bottom: 1px solid var(--paper-deep);
  }

  .row {
    display: grid;
    grid-template-columns: 4ch 1fr;
    grid-template-areas:
      'num title'
      'num ded';
    gap: var(--space-2) var(--space-6);
    align-items: baseline;
    padding: var(--space-6) var(--space-4);
    color: var(--ink);
    text-decoration: none;
  }
  @media (min-width: 64rem) {
    .row {
      grid-template-columns: 5ch minmax(20ch, 36ch) 1fr;
      grid-template-areas: 'num title ded';
      gap: var(--space-8);
      padding: var(--space-8) var(--space-6);
    }
  }
  @media (max-width: 47.99rem) {
    .row {
      grid-template-columns: 1fr;
      grid-template-areas:
        'num'
        'title'
        'ded';
      gap: var(--space-2);
      padding: var(--space-6) var(--space-4);
    }
  }

  .numeral {
    grid-area: num;
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: var(--step-2);
    color: var(--library-green);
    line-height: 1;
    display: inline-block;
  }
  @media (min-width: 64rem) {
    .numeral {
      font-size: var(--step-3);
    }
  }

  .title {
    grid-area: title;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-2);
    line-height: 1.15;
    letter-spacing: 0.01em;
  }
  @media (min-width: 64rem) {
    .title {
      font-size: var(--step-2);
    }
  }

  .dedication {
    grid-area: ded;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--step-1);
    color: var(--ink-soft);
    line-height: 1.4;
  }
  @media (min-width: 64rem) {
    .dedication {
      font-size: var(--step-1);
    }
  }

  .cta-row {
    margin-top: var(--space-12);
    text-align: center;
  }
  .cta {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--library-green);
    padding-bottom: 4px;
    display: inline-block;
  }
</style>
