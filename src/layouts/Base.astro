---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'
import { locales, defaultLocale, hreflang, type Locale } from '../i18n/config'
import { localizePath, getLocaleFromUrl } from '../i18n/locale'
import { t } from '../i18n/t'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import Grain from '../components/Grain.astro'

interface Props {
  title?: string
  description?: string
  locale?: Locale
  /** Path of the current page in canonical (ES) form, without locale
   * prefix. Used for hreflang alternates and the language switcher. */
  pathname?: string
  /** Render `<meta name="robots" content="noindex">` for unlisted pages
   * (Publishers' Room may opt in later). */
  noindex?: boolean
  /** Hide the chrome — used by /dev/* QA pages so they show only the
   * thing under test. */
  bare?: boolean
}

const detectedLocale = getLocaleFromUrl(Astro.url)
const {
  locale = detectedLocale,
  pathname = Astro.url.pathname,
  title = t('meta.home.title', locale),
  description = t('meta.home.description', locale),
  noindex = false,
  bare = false
} = Astro.props

const site = Astro.site?.toString().replace(/\/$/, '') ?? ''
const canonical = site + localizePath(pathname, locale)
---

<!doctype html>
<html lang={locale} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link
      rel="preload"
      href="/fonts/cormorant-300-italic.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      locales.map((code) => (
        <link
          rel="alternate"
          hreflang={hreflang[code]}
          href={site + localizePath(pathname, code)}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={site + localizePath(pathname, defaultLocale)}
    />
    <meta property="og:locale" content={locale} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {
      locales
        .filter((code) => code !== locale)
        .map((code) => <meta property="og:locale:alternate" content={code} />)
    }
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <ClientRouter />
    <slot name="head" />
  </head>
  <body data-locale={locale}>
    <a class="skip-to-content" href="#main">{t('aria.skip_to_content', locale)}</a>
    <Grain />
    {!bare && <SiteHeader locale={locale} pathname={pathname} />}
    <main id="main">
      <slot />
    </main>
    {!bare && <SiteFooter locale={locale} pathname={pathname} />}
  </body>
</html>

<style>
  body {
    /* Reserve a stacking context above the grain overlay. */
    position: relative;
  }

  body > main {
    position: relative;
    z-index: 2;
  }

  .skip-to-content {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--paper);
    color: var(--ink);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--step--1);
    z-index: 100;
  }
  .skip-to-content:focus-visible {
    left: var(--space-4);
    top: var(--space-4);
    outline: 2px solid var(--library-green);
    outline-offset: 2px;
  }
</style>
