---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'
import { locales, defaultLocale, hreflang, type Locale } from '../i18n/config'
import { localizePath, getLocaleFromUrl } from '../i18n/locale'
import { t } from '../i18n/t'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import ProposalSwitcher from '../components/ProposalSwitcher.astro'
import Grain from '../components/Grain.astro'

interface Props {
  title?: string
  description?: string
  locale?: Locale
  /** Path of the current page in canonical (ES) form, without locale
   * prefix. Used for hreflang alternates and the language switcher. */
  pathname?: string
  /** Render `<meta name="robots" content="noindex">` for unlisted pages
   * (Publishers' Room may opt in later). */
  noindex?: boolean
  /** Hide the chrome — used by /dev/* QA pages so they show only the
   * thing under test. */
  bare?: boolean
  /** Proposal subtree this page lives in. Drives nav prefixing and the
   * overscroll sequence. `undefined` = hub or stand-alone. */
  proposal?: 'a' | 'b'
}

const detectedLocale = getLocaleFromUrl(Astro.url)
const {
  locale = detectedLocale,
  pathname = Astro.url.pathname,
  title = t('meta.home.title', locale),
  description = t('meta.home.description', locale),
  noindex = false,
  bare = false,
  proposal
} = Astro.props

const site = Astro.site?.toString().replace(/\/$/, '') ?? ''
const canonical = site + localizePath(pathname, locale)
---

<!doctype html>
<html lang={locale} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link
      rel="preload"
      href="/fonts/cormorant-300-italic.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      locales.map((code) => (
        <link
          rel="alternate"
          hreflang={hreflang[code]}
          href={site + localizePath(pathname, code)}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={site + localizePath(pathname, defaultLocale)}
    />
    <meta property="og:locale" content={locale} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {
      locales
        .filter((code) => code !== locale)
        .map((code) => <meta property="og:locale:alternate" content={code} />)
    }
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <ClientRouter />
    <slot name="head" />
  </head>
  <body data-locale={locale}>
    <a class="skip-to-content" href="#main">{t('aria.skip_to_content', locale)}</a>
    <Grain />
    {!bare && <SiteHeader locale={locale} pathname={pathname} proposal={proposal} />}
    <main id="main">
      <slot />
    </main>
    {!bare && <SiteFooter locale={locale} pathname={pathname} />}
    {proposal && <ProposalSwitcher proposal={proposal} locale={locale} />}

    <script>
      /* Overscroll → next page. Lectura editorial secuencial: cuando el
       * usuario llega al fondo de una página y empuja hacia abajo una
       * vez más (rueda, trackpad, swipe, ↓/PgDn/Espacio/End), navega a
       * la siguiente. Una sola dirección, suave, sin scroll-jacking
       * dentro de la página. La última página (/epilogo) no avanza. */
      const SEQUENCES: Record<string, readonly string[]> = {
        a: ['/a', '/a/servicios', '/a/publishers', '/a/historias', '/a/nota', '/a/epilogo']
      }

      function splitLocale(pathname: string): { locale: string; canonical: string } {
        const m = pathname.match(/^\/(ca|fr|en|it)(\/.*)?$/)
        if (m) return { locale: '/' + m[1], canonical: m[2] || '/' }
        return { locale: '', canonical: pathname || '/' }
      }

      function nextHref(pathname: string): string | null {
        const { locale, canonical } = splitLocale(pathname)
        const stripped = canonical.replace(/\/$/, '') || '/'
        const proposalKey = stripped.match(/^\/(a|b)\b/)?.[1]
        if (!proposalKey) return null
        const sequence = SEQUENCES[proposalKey]
        const idx = sequence.indexOf(stripped)
        if (idx < 0 || idx >= sequence.length - 1) return null
        return locale + sequence[idx + 1]
      }

      function mountOverscrollNav() {
        const target = nextHref(location.pathname)
        if (!target) return

        let firing = false
        let lastTouchY = 0

        const atBottom = () => {
          const doc = document.documentElement
          return window.scrollY + window.innerHeight >= doc.scrollHeight - 2
        }
        const trigger = async () => {
          if (firing || !atBottom()) return
          firing = true
          const { navigate } = await import('astro:transitions/client')
          navigate(target)
        }

        const onWheel = (e: WheelEvent) => {
          if (e.deltaY > 0) trigger()
        }
        const onTouchStart = (e: TouchEvent) => {
          lastTouchY = e.touches[0]?.clientY ?? 0
        }
        const onTouchMove = (e: TouchEvent) => {
          const y = e.touches[0]?.clientY ?? 0
          if (lastTouchY - y > 0) trigger()
          lastTouchY = y
        }
        const onKey = (e: KeyboardEvent) => {
          if (
            atBottom() &&
            (e.key === 'ArrowDown' ||
              e.key === 'PageDown' ||
              e.key === ' ' ||
              e.key === 'End')
          ) {
            trigger()
          }
        }

        window.addEventListener('wheel', onWheel, { passive: true })
        window.addEventListener('touchstart', onTouchStart, { passive: true })
        window.addEventListener('touchmove', onTouchMove, { passive: true })
        window.addEventListener('keydown', onKey)

        document.addEventListener(
          'astro:before-swap',
          () => {
            window.removeEventListener('wheel', onWheel)
            window.removeEventListener('touchstart', onTouchStart)
            window.removeEventListener('touchmove', onTouchMove)
            window.removeEventListener('keydown', onKey)
          },
          { once: true }
        )
      }
      document.addEventListener('astro:page-load', mountOverscrollNav)

      /* T11 / T05 — single IntersectionObserver for entrance motions
       * (m-rise, m-fade-in, m-mask-wipe, m-stroke-draw). Components
       * declare data-motion only; this observer flips data-in-view at
       * 25% visibility, once. The hero uses its own choreography
       * controller (Hero.astro) and ignores this observer. */
      function mountObserver() {
        const targets = document.querySelectorAll<HTMLElement>(
          '[data-motion="m-rise"]:not([data-hero] [data-motion]),' +
            '[data-motion="m-fade-in"]:not([data-hero] [data-motion]),' +
            '[data-motion="m-stroke-draw"]:not([data-hero] [data-motion])'
        )
        if (!targets.length) return
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.setAttribute('data-in-view', '')
                io.unobserve(entry.target)
              }
            }
          },
          { threshold: 0.25 }
        )
        for (const el of targets) io.observe(el)
      }
      document.addEventListener('astro:page-load', mountObserver)
    </script>
  </body>
</html>

<style>
  body {
    /* Reserve a stacking context above the grain overlay. */
    position: relative;
  }

  body > main {
    position: relative;
    z-index: 2;
  }

  .skip-to-content {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--paper);
    color: var(--ink);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--step--1);
    z-index: 100;
  }
  .skip-to-content:focus-visible {
    left: var(--space-4);
    top: var(--space-4);
    outline: 2px solid var(--library-green);
    outline-offset: 2px;
  }
</style>
