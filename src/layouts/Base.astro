---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  lang?: string
}

const {
  title = 'Atelier de Libros',
  description = 'Curaduría literaria — el libro como identidad.',
  lang = 'es'
} = Astro.props
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
