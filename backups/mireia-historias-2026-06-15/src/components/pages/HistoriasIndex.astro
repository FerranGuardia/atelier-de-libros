---
/* T25 — Historias index. List of cases, asymmetric grid. M05 lorem cases
 * shown today; real cases land via the M05 backlog. */

import { Image } from 'astro:assets'
import casaFilomenaImage from '../../assets/historias/casa-filomena/index.webp'
import heyChabbelaImage from '../../assets/historias/hey-chabbela/index.webp'
import salonLiterarioImage from '../../assets/historias/salon-literario/index.webp'
import { t } from '../../i18n/t'
import { localizePath } from '../../i18n/locale'
import type { Locale } from '../../i18n/config'

interface Props {
  locale: Locale
}
const { locale } = Astro.props

const cases = [
  { id: 'casa_filomena', slug: 'casa-filomena' },
  { id: 'hey_chabbela', slug: 'hey-chabbela' },
  { id: 'salon_literario', slug: 'salon-literario' }
] as const

const caseImages = {
  casa_filomena: casaFilomenaImage,
  hey_chabbela: heyChabbelaImage,
  salon_literario: salonLiterarioImage
}
---

<article class="historias-index" data-motion="m-rise">
  <header class="container intro">
    <div class="intro-copy">
      <h1 class="t-page-title">{t('historias.page_title', locale)}</h1>
      <p class="lead t-lead measure-body">{t('historias.intro', locale)}</p>
    </div>
  </header>

  <ul class="cases container">
    {
      cases.map(({ id, slug }, i) => {
        const eyebrow = t(`historias.cases.${id}.eyebrow` as any, locale)
        const title = t(`historias.cases.${id}.title` as any, locale)
        const location = t(`historias.cases.${id}.location` as any, locale)
        const excerpt = t(`historias.cases.${id}.excerpt` as any, locale)
        const orientation = i % 2 === 0 ? 'left' : 'right'
        const scale = i === 0 ? 'featured' : 'quiet'
        return (
          <li class={`case is-${orientation} is-${scale}`} data-motion="m-rise">
            <article>
              <a class="image-wrap" href={localizePath(`/historias/${slug}`, locale)}>
                <Image
                  class="case-image"
                  src={caseImages[id]}
                  alt={`${title} — ${location}`}
                  widths={[480, 768, 1024, 1200]}
                  sizes="(min-width: 64rem) 45vw, calc(100vw - 64px)"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </a>
              <a class="caption" href={localizePath(`/historias/${slug}`, locale)}>
                <p class="case-eyebrow t-caption">{eyebrow}</p>
                <h2 class="case-title">{title}</h2>
                <p class="case-location t-caption">{location}</p>
                <p class="case-excerpt measure-body">{excerpt}</p>
                <span class="read-more" data-motion="m-underline-roll">
                  {t('cta.read_more', locale)}
                </span>
              </a>
            </article>
            <!-- M05 DRAFT (TFM §Casos prácticos) — fotografía pendiente -->
          </li>
        )
      })
    }
  </ul>
</article>

<style>
  .historias-index {
    margin-top: var(--space-24);
    margin-bottom: var(--space-32);
  }
  .intro {
    margin-bottom: var(--space-24);
    align-items: end;
  }
  .intro-copy {
    grid-column: 1 / -1;
  }
  .intro h1 {
    margin-bottom: var(--space-6);
  }
  .lead {
    color: var(--ink-soft);
    max-width: 56ch;
  }
  @media (min-width: 64rem) {
    .intro-copy {
      grid-column: 1 / 7;
    }
  }

  .cases {
    list-style: none;
    padding-block: 0;
    padding-inline: var(--container-pad);
    margin-block: 0;
    display: grid;
    gap: var(--space-24);
  }

  .case article {
    display: grid;
    gap: var(--space-6);
  }
  .case:not(:first-child) {
    padding-top: var(--space-16);
    border-top: 1px solid var(--paper-deep);
  }

  @media (min-width: 64rem) {
    .cases {
      gap: var(--space-24);
    }
    .case article {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: var(--gutter);
      align-items: center;
    }
    .case:not(:first-child) {
      padding-top: var(--space-24);
    }
    .case.is-featured article > .image-wrap {
      grid-column: 1 / 7;
      grid-row: 1;
    }
    .case.is-featured article > .caption {
      grid-column: 8 / 12;
      grid-row: 1;
    }
    .case.is-quiet.is-left article > .image-wrap {
      grid-column: 2 / 7;
      grid-row: 1;
    }
    .case.is-quiet.is-left article > .caption {
      grid-column: 8 / 12;
      grid-row: 1;
    }
    .case.is-quiet.is-right article > .image-wrap {
      grid-column: 7 / 12;
      grid-row: 1;
    }
    .case.is-quiet.is-right article > .caption {
      grid-column: 2 / 6;
      grid-row: 1;
    }
  }

  .image-wrap {
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }
  .case-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .caption {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .case-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-whisper);
    margin-bottom: var(--space-2);
  }
  .case-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-3);
    letter-spacing: 0.01em;
    line-height: 1.15;
    color: var(--ink);
  }
  .case.is-featured .case-title {
    font-size: var(--step-4);
  }
  .case-location {
    color: var(--ink-soft);
    margin-top: var(--space-2);
  }
  .case-excerpt {
    color: var(--ink);
    margin-top: var(--space-6);
    line-height: 1.6;
    max-width: 52ch;
  }
  .read-more {
    display: inline-block;
    margin-top: var(--space-6);
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
  }

  @media (max-width: 47.99rem) {
    .historias-index {
      margin-top: var(--space-16);
    }
    .intro {
      margin-bottom: var(--space-16);
    }
    .cases {
      gap: var(--space-16);
    }
    .case:not(:first-child) {
      padding-top: var(--space-12);
    }
    .case-title,
    .case.is-featured .case-title {
      font-size: var(--step-2);
    }
    .caption {
      max-width: 34rem;
    }
  }
</style>
