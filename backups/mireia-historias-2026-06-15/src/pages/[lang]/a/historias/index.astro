---
import Base from '../../../../layouts/Base.astro'
import HistoriasIndex from '../../../../components/pages/HistoriasIndex.astro'
import { locales, defaultLocale, type Locale } from '../../../../i18n/config'
import { t } from '../../../../i18n/t'

export function getStaticPaths() {
  return locales
    .filter((code) => code !== defaultLocale)
    .map((code) => ({ params: { lang: code } }))
}

const lang = Astro.params.lang as Locale
---

<Base proposal="a"
  locale={lang}
  pathname="/a/historias"
  title={t('meta.historias.title', lang)}
  description={t('meta.historias.description', lang)}
>
  <HistoriasIndex locale={lang} />
</Base>
